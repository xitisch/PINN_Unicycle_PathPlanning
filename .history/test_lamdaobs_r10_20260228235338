import os
import numpy as np
import torch
import matplotlib.pyplot as plt
import matplotlib.patches as patches

from pinnlib.pinnsfunctions import *
from pinnlib.trainingNN import train_model


# -----------------------------
# Setup (fixed geometry)
# -----------------------------
T = 1.0
N_train = 100
N_plot = 400

lambda_phys = 1
lambda_length = 0

BC = [0, 0, 1, 0]

# Fixed obstacle (choose a challenging case)
x_c = 0.40
y_c = 0.10
r_fixed = 0.10

device = "cpu"

t_plot = torch.linspace(0.0, T, N_plot, device=device).view(-1, 1)
t_plot.requires_grad_(True)

output_folder = "figures_weight_sweep"
os.makedirs(output_folder, exist_ok=True)


# -----------------------------
# Curvature function
# -----------------------------
def compute_curvature(model, t_list, T, BC):
    nn_input = model(t_list)
    x, y, _, _, _ = hard_bc_transform(t_list, nn_input, T, BC)

    x_t  = derivative(x, t_list)
    y_t  = derivative(y, t_list)
    x_tt = derivative(x_t, t_list)
    y_tt = derivative(y_t, t_list)

    eps = 1e-6
    kappa = (x_t * y_tt - y_t * x_tt) / ((x_t**2 + y_t**2 + eps) ** (3/2))

    t_np = t_list.squeeze().detach().cpu().numpy()
    k_np = kappa.squeeze().detach().cpu().numpy()
    kappa_max = torch.max(torch.abs(kappa)).item()

    return t_np, k_np, kappa_max


def get_trajectory(model, t_list, T, BC):
    with torch.no_grad():
        nn_input = model(t_list)
        x, y, _, _, _ = hard_bc_transform(t_list, nn_input, T, BC)
    return x.squeeze().cpu().numpy(), y.squeeze().cpu().numpy()


# -----------------------------
# Sweep weights
# -----------------------------
lambda_obs_values = [1, 5, 10, 50, 100]
lambda_omega_values = [0, 1e-4, 1e-3]

scenarios = []

for lambda_omega in lambda_omega_values:
    for lambda_obs in lambda_obs_values:

        print(f"Training: λ_obs={lambda_obs}, λ_omega={lambda_omega}")

        obs = [x_c, y_c, r_fixed]

        model = train_model(
            T=T,
            BC=BC,
            obs=obs,
            epochs=2000,
            lambda_phys=lambda_phys,
            lambda_obs=lambda_obs,
            lambda_length=lambda_length,
            lambda_omega=lambda_omega,
            N=N_train
        )

        t_np, k_np, kappa_max = compute_curvature(model, t_plot, T, BC)
        x_np, y_np = get_trajectory(model, t_plot, T, BC)

        scenarios.append({
            "lambda_obs": lambda_obs,
            "lambda_omega": lambda_omega,
            "kappa_max": kappa_max,
            "x": x_np,
            "y": y_np
        })


# -----------------------------
# Plot 1: κ_max vs λ_obs
# -----------------------------
fig1, ax1 = plt.subplots(figsize=(7, 4))

for lambda_omega in lambda_omega_values:
    xs = []
    ks = []

    for s in scenarios:
        if s["lambda_omega"] == lambda_omega:
            xs.append(s["lambda_obs"])
            ks.append(s["kappa_max"])

    ax1.plot(xs, ks, marker="o", label=f"λ_omega={lambda_omega}")

ax1.set_xlabel("λ_obs")
ax1.set_ylabel(r"Max curvature $\kappa_{\max}$")
ax1.set_title("κ_max vs λ_obs for different λ_omega")
ax1.legend()
ax1.grid(True)

fig1.savefig(os.path.join(output_folder, "kappa_vs_lambda_obs.png"), dpi=300)
plt.close(fig1)


# -----------------------------
# Plot 2: Trajectories grid
# -----------------------------
fig2, axes = plt.subplots(
    len(lambda_omega_values),
    len(lambda_obs_values),
    figsize=(3.5*len(lambda_obs_values), 3*len(lambda_omega_values)),
    sharex=True,
    sharey=True
)

for i, lambda_omega in enumerate(lambda_omega_values):
    for j, lambda_obs in enumerate(lambda_obs_values):

        ax = axes[i, j]
        for s in scenarios:
            if s["lambda_obs"] == lambda_obs and s["lambda_omega"] == lambda_omega:
                ax.plot(s["x"], s["y"], linewidth=2)

        circle = patches.Circle((x_c, y_c), r_fixed, fill=True, alpha=0.15)
        edge = patches.Circle((x_c, y_c), r_fixed, fill=False, linewidth=2)
        ax.add_patch(circle)
        ax.add_patch(edge)

        ax.set_title(f"λ_obs={lambda_obs}\nλ_omega={lambda_omega}")
        ax.set_aspect("equal", adjustable="box")
        ax.grid(True)

fig2.suptitle("Trajectory sensitivity to λ_obs and λ_omega")
fig2.tight_layout(rect=[0,0,1,0.95])

fig2.savefig(os.path.join(output_folder, "trajectories_weight_sweep.png"), dpi=300)
plt.close(fig2)

print("Weight sweep experiment finished.")